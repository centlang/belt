with c;
with glib;
with gtk;
with webkit;

with std::io;

const WEBSITE = "https://centlang.org";
const APP_ID = "org.centlang.belt";

const REFRESH_ICON = "⟳";
const X_ICON = "⨉";
const BACK_ICON = "←";
const FORWARD_ICON = "→";
const PLUS_ICON = "+";
const CLOSE_ICON = "✕";

const MARGIN = 5;
const TAB_X_SPACING = 10;
const NAVIGATION_SPACING = MARGIN;
const TOOLBAR_SPACING = 20;

type Widgets {
    refresh: *mut gtk::Button,
    back: *mut gtk::Button,
    forward: *mut gtk::Button,
    entry: *mut gtk::Entry,
    progress: *mut gtk::ProgressBar,
    tabs: *mut gtk::Notebook,
}

fn get_active_webview(tabs: *mut gtk::Notebook) *mut webkit::WebView {
    let result = gtk::notebook_get_nth_page(
        tabs, gtk::notebook_get_current_page(tabs)
    );

    return result as *mut webkit::WebView;
}

fn notify_title(
    view: *mut webkit::WebView, _spec: *mut glib::ParamSpec,
    label: *mut gtk::Label
) {
    let title = webkit::web_view_get_title(view);
    gtk::label_set_text(label, title);
}

type TabCloseData {
    tabs: *mut gtk::Notebook,
    webview: *mut webkit::WebView,
}

fn tab_x_clicked(_button: *mut gtk::Button, data: *mut TabCloseData) {
    gtk::notebook_remove_page(
        data.tabs, gtk::notebook_page_num(data.tabs, data.webview)
    );

    glib::free(data as *mut c::void);
}

fn add_tab(w: *mut Widgets, url: []u8) {
    let box = gtk::box_new(gtk::Orientation::horizontal, TAB_X_SPACING);

    let label = gtk::label_new("New tab");
    gtk::box_append(box, label);

    let close = gtk::button_new_with_label(CLOSE_ICON);
    gtk::box_append(box, close);

    let webview = webkit::web_view_new();
    gtk::notebook_append_page(w.tabs, webview, box);
    gtk::notebook_set_tab_reorderable(w.tabs, webview, true);

    glib::signal_connect(
        webview, "notify::title", &notify_title as glib::Callback,
        label as *mut c::void
    );

    let data = glib::malloc(sizeof(TabCloseData)) as *mut TabCloseData;

    *data = TabCloseData {
        tabs: w.tabs,
        webview: webview,
    };

    glib::signal_connect(
        close, "clicked", &tab_x_clicked as glib::Callback,
        data as *mut c::void
    );

    connect_signals(webview, w);
    webkit::web_view_load_uri(webview, url);
}

fn entry_activate(entry: *mut gtk::Entry, w: *mut Widgets) {
    let uri = gtk::editable_get_text(entry);
    webkit::web_view_load_uri(get_active_webview(w.tabs), uri);
}

fn notify_uri(
    view: *mut webkit::WebView, _spec: *mut glib::ParamSpec, w: *mut Widgets
) {
    if view != get_active_webview(w.tabs) {
        return;
    }

    let uri = webkit::web_view_get_uri(view);

    if uri != null {
        gtk::editable_set_text(w.entry, uri.!);
    }
}

fn update_progress(view: *mut webkit::WebView, w: *mut Widgets) {
    let progress = webkit::web_view_get_estimated_load_progress(view);

    if progress < 1 {
        gtk::progress_bar_set_fraction(w.progress, progress);
    } else {
        gtk::progress_bar_set_fraction(w.progress, 0);
    }
}

fn notify_load_progress(
    view: *mut webkit::WebView, _spec: *mut glib::ParamSpec, w: *mut Widgets
) {
    if view != get_active_webview(w.tabs) {
        return;
    }

    update_progress(view, w);
}

fn update_toolbar(view: *mut webkit::WebView, w: *mut Widgets) {
    gtk::widget_set_sensitive(w.back, webkit::web_view_can_go_back(view));
    gtk::widget_set_sensitive(w.forward, webkit::web_view_can_go_forward(view));

    if webkit::web_view_is_loading(view) {
        gtk::button_set_label(w.refresh, X_ICON);
    } else {
        gtk::button_set_label(w.refresh, REFRESH_ICON);
    }
}

fn load_changed(
    view: *mut webkit::WebView, _event: webkit::LoadEvent, w: *mut Widgets
) {
    if view != get_active_webview(w.tabs) {
        return;
    }

    update_toolbar(view, w);
}

fn back_clicked(_button: *mut gtk::Button, w: *mut Widgets) {
    webkit::web_view_go_back(get_active_webview(w.tabs));
}

fn forward_clicked(_button: *mut gtk::Button, w: *mut Widgets) {
    webkit::web_view_go_forward(get_active_webview(w.tabs));
}

fn refresh_clicked(_button: *mut gtk::Button, w: *mut Widgets) {
    let webview = get_active_webview(w.tabs);

    if webkit::web_view_is_loading(webview) {
        webkit::web_view_stop_loading(webview);
    } else {
        webkit::web_view_reload(webview);
    }
}

fn plus_clicked(_button: *mut gtk::Button, w: *mut Widgets) {
    add_tab(w, WEBSITE);
}

fn tab_switched(
    _tabs: *mut gtk::Notebook, page: *mut webkit::WebView, _num: c::uint,
    w: *mut Widgets
) {
    update_toolbar(page, w);
    update_progress(page, w);
}

fn connect_signals(view: *mut webkit::WebView, w: *mut Widgets) {
    glib::signal_connect(
        view, "notify::uri", &notify_uri as glib::Callback, w as *mut c::void
    );

    glib::signal_connect(
        view, "notify::estimated-load-progress",
        &notify_load_progress as glib::Callback, w as *mut c::void
    );

    glib::signal_connect(
        view, "load-changed", &load_changed as glib::Callback, w as *mut c::void
    );
}

fn activate(app: *mut gtk::Application, _data: *c::void) {
    let window = gtk::application_window_new(app);

    let box = gtk::box_new(gtk::Orientation::vertical, 0);
    gtk::window_set_child(window, box);

    let toolbar = gtk::box_new(gtk::Orientation::horizontal, TOOLBAR_SPACING);
    gtk::box_append(box, toolbar);
    gtk::widget_set_margin_start(toolbar, MARGIN);
    gtk::widget_set_margin_end(toolbar, MARGIN);
    gtk::widget_set_margin_top(toolbar, MARGIN);
    gtk::widget_set_margin_bottom(toolbar, MARGIN);

    let navigation = gtk::box_new(
        gtk::Orientation::horizontal, NAVIGATION_SPACING
    );

    gtk::box_append(toolbar, navigation);

    let refresh = gtk::button_new_with_label(REFRESH_ICON);
    gtk::box_append(navigation, refresh);

    let back = gtk::button_new_with_label(BACK_ICON);
    gtk::box_append(navigation, back);

    let forward = gtk::button_new_with_label(FORWARD_ICON);
    gtk::box_append(navigation, forward);

    let entry = gtk::entry_new();
    gtk::box_append(toolbar, entry);
    gtk::widget_set_hexpand(entry, true);

    let progress = gtk::progress_bar_new();
    gtk::box_append(box, progress);

    let tabs = gtk::notebook_new();
    gtk::widget_set_vexpand(tabs, true);
    gtk::box_append(box, tabs);

    let plus = gtk::button_new_with_label(PLUS_ICON);
    gtk::notebook_set_action_widget(tabs, plus, gtk::PackType::end);

    let w = glib::malloc(sizeof(Widgets)) as *mut Widgets;

    *w = Widgets {
        refresh: refresh,
        back: back,
        forward: forward,
        entry: entry,
        progress: progress,
        tabs: tabs,
    };

    glib::signal_connect(
        entry, "activate", &entry_activate as glib::Callback, w as *mut c::void
    );

    glib::signal_connect(
        back, "clicked", &back_clicked as glib::Callback, w as *mut c::void
    );

    glib::signal_connect(
        forward, "clicked", &forward_clicked as glib::Callback,
        w as *mut c::void
    );

    glib::signal_connect(
        refresh, "clicked", &refresh_clicked as glib::Callback,
        w as *mut c::void
    );

    glib::signal_connect(
        plus, "clicked", &plus_clicked as glib::Callback, w as *mut c::void
    );

    glib::signal_connect(
        tabs, "switch-page", &tab_switched as glib::Callback, w as *mut c::void
    );

    add_tab(w, WEBSITE);
    add_tab(w, WEBSITE);

    gtk::window_present(window);
}

#(extern) fn main(argc: c::int, argv: **c::char) c::int {
    let app = gtk::application_new(APP_ID, glib::APPLICATION_DEFAULT_FLAGS);
    glib::signal_connect(app, "activate", &activate as glib::Callback, null);

    let status = glib::application_run(app, argc, argv);
    glib::object_unref(app);

    return status;
}
